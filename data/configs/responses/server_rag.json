{
    "experiment_name": "server_rag",
    "dataset_path": "data/experiments/references/eval/dataset_v2.json",
    "responses_dir": "data/experiments/responses",
    "ingestion": {
        "chunk_size": 500,
        "chunk_overlap": 50,
        "source_path": "data/files/raw",
        "source_type": "local_fs",
        "source_name": "local"
    },
    "retrieval": {
        "retriever_type": "hybrid",
        "per_retriever_limits": {
            "semantic": 10,
            "lexical": 10
        },
        "top_k": 5
    },
    "reranker": {
        "reranker_type": "section_boost",
        "reranker_boost": 0.25,
        "section_classifier_path": "app/classification/artifacts/section_classifier_v10.joblib",
        "section_threshold": 0
    },
    "llm": {
        "llm_name": "Qwen3-0.6B-Q4_K_M",
        "llm_max_context": 4096,
        "llm_max_tokens": 128,
        "llm_temperature": 0.7,
        "llm_stop": []
    },
    "prompt": {
        "task": "rag",
        "version": "qwen3_4b_v7",
        "root": "app/prompting/templates"
    },
    "embedding_model": {
        "embedding_model_name": "intfloat/multilingual-e5-base",
        "embedding_batch_size": 32,
        "embedding_dimension": 768
    }
}